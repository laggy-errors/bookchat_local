{
  "name": "bookchat-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev --workspace=web -- -p 3000\"",
    "start": "concurrently \"npm run start --workspace=server\" \"npm run start --workspace=web -- -p 3000\"",
    "build": "npm run build --workspace=server && npm run build --workspace=web",
    "dev:web": "npm run dev --workspace=web",
    "dev:server": "npm run dev --workspace=server",
    "build:web": "npm run build --workspace=web",
    "build:server": "npm run build --workspace=server",
    "lint": "tsc --noEmit --project apps/server/tsconfig.json"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/jsonwebtoken": "^9.0.10",
    "concurrently": "^10.0.3",
    "prisma": "^6.1.0",
    "typescript": "~5.8.2"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^6.1.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express-rate-limit": "^8.5.2",
    "gsap": "^3.15.0",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.24.0",
    "postcss": "^8.5.19",
    "react-hook-form": "^7.81.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwindcss": "^4.3.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  }
}
